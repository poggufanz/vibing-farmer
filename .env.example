# RPC
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet (jangan pakai demo wallet)
PRIVATE_KEY=0x_your_deployer_private_key

# Venice AI (gratis, dapet dari dashboard venice.ai)
VENICE_API_KEY=your_venice_api_key

# Etherscan (gratis, untuk verify contract)
ETHERSCAN_API_KEY=your_etherscan_api_key

# 1Shot: NO API KEY NEEDED - pure JSON-RPC ke https://relayer.1shotapi.com/relayers

# Diisi setelah deploy:
VAULT_DEPOSITOR_ADDRESS=0x_fill_after_deploy
MOCK_VAULT_ADDRESS=0x_fill_after_deploy

# A2A Coordination — orchestrator smart account
# Orchestrator key sekarang EPHEMERAL, di-generate di browser per-session
# (lihat src/redelegation.js). TIDAK perlu private-key env var — var berawalan
# VITE_ akan ke-inline ke client bundle publik dan kebaca siapa pun.
# Opsional: RPC Sepolia untuk public client orchestrator (default https://rpc.sepolia.org)
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Tavily web search — live DeFi market context buat prompt Venice AI.
# Server-side key (TANPA prefix VITE_) — dibaca /api/search proxy, tidak masuk client bundle.
# Opsional: kalau kosong/timeout (8s), strategy generation balik ke static knowledge.
TAVILY_API_KEY=tvly-...

# About section links (taruh di frontend/.env.local).
VITE_GITHUB_URL=https://github.com/poggufanz/vibing-farmer

# Security: allowed origin for /api/ai proxy
# Set to your Vercel deployment URL after deploy
ALLOWED_ORIGIN=https://your-app.vercel.app

